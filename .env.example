# ULTRA_MSG Integration: Required for automated WhatsApp notification messages
# Go to UltraMsg Dashboard and copy these settings
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=

# Firebase Admin SDK Credentials (Required for Cloud Messaging HTTP v1 API)
# You can get these from Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
